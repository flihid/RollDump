{
  "name": "rolldump-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "predev": "node scripts/free-dev-ports.mjs",
    "dev": "turbo run dev",
    "dev:clean": "node scripts/free-dev-ports.mjs",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^1.13.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0"
}
